  "records": {
    "description": "Recolors shulker boxes using color dyes and a crafter. The device's item to color map is set using the built-in whitelister. The device is designed to be safe, with features that prevent dry firing and ensure that the dyes are present. Without the necessary dyes, the device will not recolor the box.",
    "features": [
      "Safety features: Dry fire proof and checks if dyes are present",
      "No idle hoppercarts",
      "Fully hopperlocked",
      "Small and compact",
      "Dimensions: 23 x 12 x 7 blocks.",
      "Throughput: 125 gt.",
      "Latency: 120 gt from input to crafter activation."
    ],
    "instructions": [
      "Box input: Barrel input for shulker box containing items to be recolored",
      "Dye input: Dye items to recolor the box. 16 variants",
      "Output: Colored box via waterstream"
    ],
    "notes": "Inspired by Obi's encoder design.",
    "compatibility": "1.21+"
  },
