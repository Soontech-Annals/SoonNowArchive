  "records": {
    "description": "Takes a list of boxes, categorized by fullness, and outputs pairs of boxes to be merged. The device is capable of optimizing the merging pairs to reduce the number of merging operations required. This is done by pairing the most full box with the least full box, the second most full box with the second least full box, and so on.",
    "features": [
      "Most full box to least full box pairing",
      "Automatic output clocking, 16gt per pair",
      "Small size"
    ]
  },
