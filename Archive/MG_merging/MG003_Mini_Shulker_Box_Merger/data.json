  "records": {
    "description": "A relatively simple device that takes shulker boxes in pairs and merges the boxes in each pair together. Based on the minimum hopper layout by Floppy (MG002)",
    "features": [
      "Small; 6x8 slice, 4w frontend",
      "26 hoppers, 0 locked (FHU)",
      "8 slices for a total of 8x hopperspeed merging",
      "Status outputs for HasItems, IsActive and SlicesAvailable"
    ],
    "notes": "Roof concept by JayRoi",
    "compatibility": "1.19+"
